{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash",
      "WebSearch"
    ],
    "defaultMode": "auto"
  },
  "effortLevel": "high",
  "model": "sonnet",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "timeout 20 bash /home/ryzepeck/webapps/ops/vps/scripts/maintenance/session-start-git-status.sh 2>&1 || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "timeout 10 bash /home/ryzepeck/webapps/ops/vps/scripts/maintenance/stop-check-user-flows.sh 2>&1 || true"
          }
        ]
      }
    ]
  },
  "_meta": {
    "_comment": "Template sincronizado desde workflows/.claude/base/settings.json.tmpl. El merge mantiene las keys del proyecto que no estan aqui (e.g. settings.local.json overrides, permisos ad-hoc). Sync se hace en Fase 3a.",
    "_source": "vps-ops-toolkit/workflows/.claude/base/settings.json.tmpl",
    "_fleet_base_version": 1
  }
}
